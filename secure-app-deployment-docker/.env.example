# ── Registry access ────────────────────────────────────────────────────────
# Provided by vendor. Credentials are time-limited — contact vendor to renew.
REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
REGISTRY_USERNAME=AWS
REGISTRY_PASSWORD=<token-from-vendor>

# ── Application version ────────────────────────────────────────────────────
APP_VERSION=latest

# ── License ────────────────────────────────────────────────────────────────
LICENSE_KEY=<license-key-from-vendor>
LICENSE_SERVER_URL=https://license.yourdomain.com

# ── Optional ───────────────────────────────────────────────────────────────
# Override the API URL the frontend uses to reach the backend.
# Default: http://localhost:8000 (same-machine deployment)
NEXT_PUBLIC_API_URL=http://localhost:8000
